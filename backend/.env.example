# Google Gemini API Key for software design generation
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Optional / Unused but declared in configuration)
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL Database Connection String (e.g. Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Authentication Secrets
# Generate a strong key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
